{
	"workbench.colorCustomizations": {
		"[Best Themes - Neon City Darkvenom]": {
			"editor.background": "#0c0a20",
			"editorCursor.foreground": "#4FD6FF",
			"list.hoverBackground": "#564fe4",
			"list.activeSelectionBackground": "#5E57FF",
			"terminal.ansiGreen": "#4FD932"
		},
		"[Arasaka Inferno: Blue]": {
			"editor.background": "#0c0a20"
		}
	},
	"editor.tokenColorCustomizations": {
		"[Best Themes - Neon City Darkvenom]": {
			"textMateRules": [
				// =========================================================================
				// Shared / Generic
				// =========================================================================

				{
					"name": "Generic - Plain Text",
					"scope": [
						"variable",
						"support",
						"punctuation.decorator",
						"punctuation.definition.annotation",
						"storage.type.annotation",
						"entity.name.namespace",
						"entity.name.decorator"
					],
					"settings": {
						"foreground": "#eff1f5"
					}
				},
				{
					"name": "Generic - Functions",
					"scope": ["entity.name.function", "support.function"],
					"settings": {
						"foreground": "#00D8FF"
					}
				},
				{
					"name": "Generic - Strings",
					"scope": ["string", "string.template"],
					"settings": {
						"foreground": "#FFDC16"
					}
				},
				{
					"name": "Generic - Keywords",
					"scope": [
						"keyword",
						"keyword.control",
						"keyword.control.import",
						"keyword.control.from",
						"keyword.operator",
						"keyword.operator.arrow",
						"storage",
						"storage.type.function",
						"storage.type.function.arrow"
					],
					"settings": {
						"foreground": "#ff00a8"
					}
				},
				{
					"name": "Generic - Types",
					"scope": ["entity.name.type", "support.type"],
					"settings": {
						"foreground": "#00FF98"
					}
				},
				{
					"name": "Generic - Numbers & Literals",
					"scope": [
						"constant.language.boolean",
						"constant.language.undefined",
						"constant.language.null",
						"constant.numeric"
					],
					"settings": {
						"foreground": "#ff9d00"
					}
				},
				{
					"name": "Generic - Comments",
					"scope": [
						"comment",
						"comment.block",
						"comment.block.documentation",
						"comment.line"
					],
					"settings": {
						"foreground": "#8c8fa1"
					}
				},

				// =========================================================================
				// Shell
				// =========================================================================

				{
					"name": "Shell - Arguments",
					"scope": ["string.unquoted.argument.shell"],
					"settings": {
						"foreground": "#eff1f5"
					}
				},
				{
					"name": "Shell - Commands & Builtins",
					"scope": [
						"entity.name.command.shell",
						"support.function.builtin.shell"
					],
					"settings": {
						"foreground": "#00FF98"
					}
				},
				{
					"name": "Shell - Numbers",
					"scope": ["constant.numeric.shell"],
					"settings": {
						"foreground": "#ff9d00"
					}
				},

				// =========================================================================
				// JSON
				// =========================================================================

				{
					"name": "JSON - Keys",
					"scope": ["support.type.property-name.json", "entity.name.tag.json"],
					"settings": {
						"foreground": "#EBB7F7"
					}
				},
				{
					"name": "JSON - Values",
					"scope": ["constant.language.json", "constant.numeric.json"],
					"settings": {
						"foreground": "#BAF7FC"
					}
				},

				// =========================================================================
				// YAML
				// =========================================================================

				{
					"name": "YAML - Keys",
					"scope": ["entity.name.tag.yaml"],
					"settings": {
						"foreground": "#EBB7F7"
					}
				},
				{
					"name": "YAML - Values",
					"scope": [
						"string.quoted.double.yaml",
						"string.quoted.single.yaml",
						"string.unquoted.plain.out.yaml",
						"string.unquoted.block.yaml",
						"constant.numeric.yaml",
						"constant.numeric.integer.decimal.yaml",
						"constant.language.boolean.yaml",
						"constant.other.option"
					],
					"settings": {
						"foreground": "#BAF7FC"
					}
				},

				// =========================================================================
				// Markdown
				// =========================================================================

				{
					"name": "Markdown - Headings",
					"scope": [
						"markup.heading",
						"markup.heading.markdown",
						"entity.name.section.markdown",
						"punctuation.definition.heading.markdown"
					],
					"settings": {
						"foreground": "#12B8FF"
					}
				},
				{
					"name": "Markdown - Body Text",
					"scope": ["meta.paragraph.markdown", "markup.table.markdown"],
					"settings": {
						"foreground": "#eff1f5"
					}
				},
				{
					"name": "Markdown - Italic",
					"scope": [
						"markup.italic.markdown",
						"punctuation.definition.italic.markdown"
					],
					"settings": {
						"foreground": "#CCC"
					}
				},
				{
					"name": "Markdown - Bold",
					"scope": [
						"markup.bold.markdown",
						"punctuation.definition.bold.markdown"
					],
					"settings": {
						"foreground": "#ff5dce"
					}
				},
				{
					"name": "Markdown - Links",
					"scope": ["markup.underline.link.markdown"],
					"settings": {
						"foreground": "#12B8FF"
					}
				},
				{
					"name": "Markdown - Link URLs",
					"scope": [
						"meta.link.inline.markdown",
						"meta.link.reference.markdown",
						"string.other.link.title.markdown"
					],
					"settings": {
						"foreground": "#FFDC16"
					}
				},
				{
					"name": "Markdown - Inline & Block Code",
					"scope": [
						"markup.inline.raw",
						"markup.inline.raw.string.markdown",
						"markup.fenced_code.block.markdown",
						"markup.raw.block.markdown",
						"fenced_code.block.language.markdown",
						"punctuation.definition.raw.markdown"
					],
					"settings": {
						"foreground": "#BAF7FC"
					}
				},
				{
					"name": "Markdown - Lists",
					"scope": [
						"markup.list",
						"punctuation.definition.list.begin.markdown"
					],
					"settings": {
						"foreground": "#ff00a8"
					}
				},
				{
					"name": "Markdown - Blockquotes",
					"scope": [
						"markup.quote",
						"punctuation.definition.blockquote.markdown"
					],
					"settings": {
						"foreground": "#8c8fa1"
					}
				},
				{
					"name": "Markdown - Structural Punctuation",
					"scope": [
						"punctuation.definition.markdown",
						"punctuation.separator.table.markdown"
					],
					"settings": {
						"foreground": "#8c8fa1"
					}
				}
			]
		}
	},

	"editor.tabSize": 2,
	"editor.fontSize": 16,
	"editor.lineHeight": 26,
	"editor.rulers": [80, 120],
	"editor.fontFamily": "JetBrains Mono",
	"editor.fontLigatures": true,
	"editor.cursorBlinking": "solid",
	"editor.cursorSmoothCaretAnimation": "off",
	"editor.semanticHighlighting.enabled": false,
	"editor.bracketPairColorization.enabled": true,
	"editor.guides.highlightActiveBracketPair": true,
	"editor.guides.bracketPairsHorizontal": true,
	"editor.guides.indentation": true,
	"editor.guides.highlightActiveIndentation": "always",
	"editor.guides.bracketPairs": "active",
	"editor.scrollbar.vertical": "auto",
	"editor.renderLineHighlight": "gutter",
	"editor.minimap.enabled": false,
	"editor.minimap.size": "fit",
	"editor.suggestSelection": "first",
	"editor.linkedEditing": true,
	"editor.unicodeHighlight.allowedLocales": {
		"pt-BR": true
	},

	"workbench.colorTheme": "Best Themes - Neon City Darkvenom",
	"workbench.iconTheme": "material-icon-theme",
	"workbench.startupEditor": "newUntitledFile",
	"workbench.editor.empty.hint": "hidden",
	"workbench.editor.labelFormat": "short",
	"workbench.editor.showTabs": "multiple",
	"workbench.editor.limit.enabled": true,
	"workbench.editor.limit.value": 5,
	"workbench.editor.limit.perEditorGroup": true,
	"workbench.activityBar.location": "hidden",
	"workbench.statusBar.visible": true,
	"workbench.list.defaultFindMode": "filter",
	"workbench.list.typeNavigationMode": "automatic",
	"workbench.list.defaultFindMatchType": "fuzzy",
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"workbench.layoutControl.enabled": false,
	"workbench.browser.showInTitleBar": false,
	"workbench.browser.openLocalhostLinks": false,

	"search.exclude": {
		"**/node_modules": true,
		"**/.git": true,
		"**/dist": true,
		"**/target": true,
		"**/bin": true,
		"**/bower_components": true,
		"**/*.code-search": true,
		"**/.turbo": true
	},
	"breadcrumbs.enabled": true,
	"breadcrumbs.filePath": "on",
	"breadcrumbs.symbolPath": "last",
	"breadcrumbs.icons": true,

	"explorer.incrementalNaming": "simple",
	"explorer.compactFolders": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": true,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.sortOrder": "foldersNestsFiles",
	"explorer.fileNesting.patterns": {
		"*.ts": "${capture}.*.ts",
		"*.js": "${capture}.*.js, ${capture}.*.ts, ${capture}.*.map",
		"*.jsx": "${capture}.js",
		"*.tsx": "${capture}.*.tsx",
		"tsconfig.json": "tsconfig.*.json",
		"package.json": "package-lock*, yarn*, pnpm*, .npm*, eslint*, .eslint*, prettier*, .prettier*, biome*, tsconfig*, .nvm*, .editorconfig",
		"vite.config.*": "tailwind*, postcss*",
		"jest.*": ".swc*",
		"*ockerfile": "docker*, .docker*",
		".env": ".env*, .example.env",
		".gitignore": ".git*",
		"app.*": "babel*, eas*",
		"*.go": "${capture}_*.go",
		"go.mod": "go.sum",
		"README.md": "*.md",
		"Cargo.toml": "Cargo*, rust*",
		"*.sqlite": "${capture}.${extname}-*",
		"*.db": "${capture}.${extname}-*",
		"*.sqlite3": "${capture}.${extname}-*",
		"*.db3": "${capture}.${extname}-*",
		"*.sdb": "${capture}.${extname}-*",
		"*.s3db": "${capture}.${extname}-*"
	},

	"terminal.integrated.fontSize": 15,
	"terminal.integrated.showExitAlert": false,
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.enableMultiLinePasteWarning": "auto",
	"terminal.integrated.shellIntegration.decorationsEnabled": "never",
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.env.windows": {},
	"terminal.integrated.env.linux": {},

	"git.openRepositoryInParentFolders": "always",
	"gitlens.hovers.currentLine.over": "line",
	"gitlens.currentLine.pullRequests.enabled": false,
	"gitlens.currentLine.scrollable": false,
	"gitlens.hovers.enabled": false,
	"gitlens.currentLine.enabled": false,
	"gitlens.codeLens.enabled": false,

	"zenMode.hideLineNumbers": false,
	"zenMode.centerLayout": false,
	"zenMode.hideActivityBar": true,
	"zenMode.hideStatusBar": true,
	"zenMode.showTabs": "single",

	"diffEditor.ignoreTrimWhitespace": true,
	"diffEditor.codeLens": true,

	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.addMissingImports": "explicit",
		"source.removeUnused": "explicit"
	},

	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 300,
	"files.exclude": {
		"**/node_modules": true,
		"**/.git": true,
		"**/.vscode": false,
		"**/.nx": true,
		"**/.DS_Store": true
	},
