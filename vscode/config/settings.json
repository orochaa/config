	"tailwindCSS.experimental.classRegex": [
		["(?:cn,clsx,twMerge)\\(([^)]*)\\)", "(?:'|\"|`)([^'\"`]*)(?:'|\"|`)"],
		["tv\\(([^)]*)\\)", "(?:'|\"|`)([^'\"`]*)(?:'|\"|`)"],
		["(?:class|className)\\s*:\\s*[\"'`]([^\"'`]*)[\"'`]"],
		[
			"(?:class|className|containerClassName|wrapperClassName|contentClassName|iconClassName)\\s*[:=]\\s*[\"'`]([^\"'`]*)[\"'`]"
		],
		[
			"(?:class|className|containerClassName|wrapperClassName|contentClassName|iconClassName)\\s*[:=]\\s*{([^}]*)}"
		]
	],

