[user]
	name = Bruno Rocha
	email = brunorocha2674@gmail.com
[alias]
	# Setup
	setup = !git remote set-head origin -a
	base = !git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'
	g = !code ~/.gitconfig
	alias = "!git config --get-regexp '^alias' | fzf --no-preview --exact"
	
  # Status / logs
	s = !git status -s
	sc = !git status -s | awk '{print $2}'
	staged = !git diff --cached	--name-only
	l = !git log --pretty=format:'%C(blue)%h%C(red)%d %C(white)%s - %C(cyan)%cn %C(green)%cr'
	la = !git l -1
	last = !git log -1 HEAD --stat

  # Branches
  cur = !git branch --show-current
  b = !git branch -vv
  bd = "!f(){ target=${1:-$(git sb)}; [ -n \"$target\" ] && git branch -D $target || echo \"Cancelled\"; }; f"
	ck = !git checkout
  sw = !git switch
	back = !git switch -
	pivot = !git branch -m
	main = "!base=$(git base); git switch \"$base\" && git pull origin \"$base\""
	recent = "!git for-each-ref refs/heads/ --sort=-committerdate --format='%(refname:short)'"
	sb = "!git recent | fzf --no-preview --multi --prompt='branch: ' --reverse --height=40%"
  ss = "!f(){ target=$(git sb); [ -n \"$target\" ] && git switch \"$target\" || echo \"Cancelled\"; }; f"
	new = "!f(){ git main && git switch -c \"$1\"; }; f"
	resume = "!f(){ [ -n \"$1\" ] && git switch -c \"$1\" --track \"origin/$1\" || echo \"Target not found\"; }; f"
	done = "!cur=$(git cur); git main && git branch -D \"$cur\""
	park = "!cur=$(git cur); git add --all && git commit -m \"__PARKED_WIP__:$cur\" && git main"
	unpark = "!f(){ log=$(git log --all --grep='^__PARKED_WIP__:' --format='%s' -n 1); branch=${log#__PARKED_WIP__:}; [ -n \"$branch\" ] && git switch \"$branch\" && git undo || echo 'No parked branch found'; }; f"
	parked = "!git l --all --grep='^__PARKED_WIP__:'"

  # Commits
	c = !git add --all && git commit -m
	cm = !git commit -m
	a = !git commit --amend
	aa = !git add --all && git commit --amend --no-edit
	same = "!f(){ msg=$(git log --pretty=format:'%s' $(git cur) | awk '!seen[$0]++' | fzf --no-preview --exact --prompt='message: ' --reverse --height=40%); [ -n \"$msg\" ] && git add --all && git commit -m \"$msg\" || echo 'Cancelled'; }; f"
	wip = !git c 'wip'
	clint = !git c 'fix: lint'
	cformat = !git c 'fix: format'
	ctype = !git c 'fix: type-check'
	cbuild = !git c 'fix: build'
	ctests = !git c 'fix: tests'

  # Pull
	pm = !git pull origin $(git base)
	pb = !git pull origin $(git cur)
	refresh = "!cur=$(git cur); git main && git switch \"$cur\""
	mg = "!f(){ target=$(git sb); [ -n \"$target\" ] && git merge \"$target\" || echo 'Cancelled'; }; f"

	resolve= "!f(){ \
		only='packages/frontend/src-tauri/tauri.conf.json'; \
		git merge --no-edit \"origin/$1\"; \
		rc=$?; \
		if [ $rc -eq 0 ]; then \
			return 0; \
		fi; \
		conflicts=$(git diff --name-only --diff-filter=U); \
		count=$(printf '%s\n' \"$conflicts\" | sed '/^$/d' | wc -l | tr -d ' '); \
		if [ \"$count\" -eq 1 ] && [ \"$conflicts\" = \"$only\" ]; then \
			printf '\n> Auto-resolving tauri.conf.json using incoming version...\n'; \
			git checkout --theirs -- \"$only\" && \
			git add \"$only\" && \
			GIT_EDITOR=true git commit --no-edit; \
			return $?; \
		fi; \
    printf '\n> Merge has unresolved conflicts. Aborting.\n'; \
    return 1; \
	}; f"
	sync = "!f(){ \
    printf '> Fetching origin...\n'; \
    git fetch origin || return 1; \
    base=$(git base); \
    cur=$(git cur); \
    printf '\n> Merging origin/%s...\n' \"$base\"; \
    git resolve \"$base\" || return 1; \
    printf '\n> Merging origin/%s...\n' \"$cur\"; \
    git resolve \"$cur\" || return 1; \
    printf '\n> Pushing %s...\n' \"$cur\"; \
    git push origin \"$cur\"; \
	}; f"

  # Push
	po = !git push origin
  pf = !git push origin --force-with-lease
	pd = !git push origin --delete
	pr = !git push origin && git push origin --tags

	# Merge Conflicts
	conflicts = !git diff --name-only --diff-filter=U
	ours = !git checkout --ours
	theirs = !git checkout --theirs

	# File states
	deleted = !git diff --name-only --diff-filter=D
	added = !git diff --name-only --diff-filter=A
	modified = !git diff --name-only --diff-filter=M
	renamed = !git diff --name-only --diff-filter=R

	# Review
	review = "!git diff origin/$(git base)...HEAD --stat"
  reviewf = "!git review | fzf --multi --no-preview --exact --reverse"
	changed = "!f(){ base=$(git base); { git diff --name-only origin/$base...HEAD; git diff --name-only; git diff --cached --name-only; git ls-files --others --exclude-standard; } | sort -u; }; f"
  changedf = "!git changed | fzf --multi --no-preview --exact --reverse"
	affected = "!git diff --name-only origin/$(git base)...HEAD | cut -d/ -f1-2 | sort -u"

	# Remote
	r = !git remote -v
	ra = !git remote add
	rr = !git remote rename
	rd = !git remote remove
	rs = !git remote set-url

	# Utils
	undo = !git reset --soft HEAD^ && git reset
	patch = !git diff --staged > wip.patch
	port = "!f(){ target=$(git sb); git diff $(git cur)..$target -- $@ | git apply; }; f"

	ignore = !git update-index --skip-worktree
	unignore = !git update-index --no-skip-worktree
	
	# Debug
	dup = "!git config --get-regexp '^alias' | awk '{print $1}' | sort | uniq -d"
	dedup = "!git dup | while read k; do echo \"=== $k ===\"; git config --show-origin --get-all $k; done"
	where = "!f(){ git config --show-origin --get-all alias.$1; }; f"
[core]
	editor = nano
	pager = delta
	sshCommand = /home/unvoid/git/orochaa/config/git/ssh-proxy.sh
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	side-by-side = false
[init]
	defaultBranch = main
[pull]
	rebase = false
[includeIf "gitdir:/home/unvoid/git/unvoid/**"]
	path = /home/unvoid/.gitconfig-unvoid
[includeIf "gitdir:/home/unvoid/git/orochaa/**"]
	path = /home/unvoid/.gitconfig-personal
[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[push]
	autoSetupRemote = true
	default = current
